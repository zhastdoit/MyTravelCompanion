# Copy to .env.local and fill in. Public (`NEXT_PUBLIC_*`) values are bundled
# into the browser; everything else stays server-only.

# ---------------------------------------------------------------------------
# Public (browser) — anything readable by a curl on the deployed site
# ---------------------------------------------------------------------------

# Mapbox GL JS access token. Required for the live map. Get one at
# https://account.mapbox.com/access-tokens/. The TripMap renders a labelled
# placeholder when missing, so the rest of the UI still works.
NEXT_PUBLIC_MAPBOX_TOKEN=

# (Not required — we self-host the CopilotKit runtime in
# app/api/copilotkit/route.ts and bridge chat to FastAPI via FastApiAgent.
# Only set this if you switch to CopilotKit Cloud, i.e. swap the runtimeUrl
# for `https://api.cloud.copilotkit.ai`.)
# NEXT_PUBLIC_COPILOTKIT_PUBLIC_API_KEY=

# Supabase project — `Project URL` and `anon / public` key from
# https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Where this app is reachable. Used by the share dialog and the auth
# redirect URL. Override per env (Vercel preview / production).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Server-only — read in route handlers / middleware, never sent to browser
# ---------------------------------------------------------------------------

# Base URL of the FastAPI agent server. The /api/copilotkit chat agent and the
# /api/trip/* proxies all read this. Defaults to http://localhost:8000.
BACKEND_URL=http://localhost:8000
