# --- Frontend (public, exposed to the browser) ---

# Mapbox GL JS access token. Required for the live map. Get one at
# https://account.mapbox.com/access-tokens/. The TripMap renders a labelled
# placeholder when this is missing, so the rest of the UI still works.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: CopilotKit Cloud public API key. Leave blank to run locally
# against the OPENAI_API_KEY adapter below.
NEXT_PUBLIC_COPILOTKIT_PUBLIC_API_KEY=

# --- Backend (server-only, never sent to the browser) ---

# OpenAI key used by the local CopilotRuntime OpenAIAdapter fallback.
OPENAI_API_KEY=

# Optional: override the default OpenAI model. Defaults to gpt-4o-mini.
OPENAI_MODEL=

# Optional: when set, /api/copilotkit proxies to a remote CopilotKit-compatible
# endpoint (e.g. the FastAPI agent server from Track 2). Leave blank to run
# the runtime entirely on the Next.js gateway with the OpenAI adapter.
COPILOT_BACKEND_URL=
