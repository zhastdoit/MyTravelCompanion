# Copy to .env and fill in as needed.

# LLM mode: 1 = deterministic mock (no key needed), 0 = real OpenAI
USE_MOCK_LLM=1

# Real OpenAI mode
OPENAI_API_KEY=

# Hard per-session spend cap (USD). Agents stop once a session crosses this.
SESSION_USD_CAP=1.0

# Optional model overrides (defaults: smart=gpt-4o, fast=gpt-4o-mini)
MODEL_SMART=gpt-4o
MODEL_FAST=gpt-4o-mini

# HOT store (optional — falls back to in-memory if unreachable)
REDIS_URL=redis://localhost:6379

# Weave observability (optional — set to enable @op tracing)
# WEAVE_PROJECT=your-wandb-entity/synctrip
WANDB_API_KEY=
