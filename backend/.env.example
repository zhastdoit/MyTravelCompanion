# Copy to .env and fill in as needed.
#
# All keys below are READ AT STARTUP via python-dotenv (see main.py top). The
# server falls back to safe defaults / mock paths whenever a key is missing,
# so it boots even with this file empty — but real product features (live
# travel APIs, real LLM, Supabase auth, cold trips) require their respective
# keys.

# ---------------------------------------------------------------------------
# LLM
# ---------------------------------------------------------------------------

# 1 = deterministic mock (no key needed), 0 = real OpenAI.
# When 0, OPENAI_API_KEY must be set; otherwise the orchestrator returns an
# error reply rather than crashing.
USE_MOCK_LLM=0

# Real OpenAI mode. Required when USE_MOCK_LLM=0.
# Get one: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Hard per-session spend cap (USD). Agents stop once a session crosses this.
# The frontend's TelemetryStrip turns red as it approaches the cap.
SESSION_USD_CAP=1.0

# Optional model overrides (defaults: smart=gpt-4o, fast=gpt-4o-mini).
# Pricing for these models lives in cost.py.
MODEL_SMART=gpt-4o
MODEL_FAST=gpt-4o-mini

# ---------------------------------------------------------------------------
# External travel APIs
# ---------------------------------------------------------------------------

# 1 = always use the deterministic fixtures in tools.py (offline / demos).
# 0 = call the real APIs below; missing keys per-API fall back to mocks.
MOCK_EXTERNAL_APIS=0

# SerpApi (Google Flights). Sign up: https://serpapi.com
# Free tier: ~100 calls/month. Powers query_amadeus.
SERPAPI_API_KEY=

# Geoapify (geocoding + Places). Sign up: https://myprojects.geoapify.com/
# Free tier: 3000 calls/day. Powers query_geoapify.
GEOAPIFY_API_KEY=

# OpenWeatherMap (5-day forecast). Sign up: https://home.openweathermap.org/api_keys
# Free tier: 1M calls/month. Powers check_weather.
OPENWEATHER_API_KEY=

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------

# HOT TripState store. Use rediss:// for Upstash (TLS). Falls back to in-memory
# if unreachable. Get one: https://console.upstash.com/redis
REDIS_URL=redis://localhost:6379

# Tag the redis key prefix so prod and dev don't collide on a shared instance.
SYNCTRIP_ENV=dev

# Supabase project (auth + cold trips storage). Get the values from
# https://supabase.com/dashboard/project/<id>/settings/api
# Use the BASE PROJECT URL (https://<id>.supabase.co), no /rest/v1 suffix.
SUPABASE_URL=
# Service-role key — server-only, NEVER ship to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 secret. Leave EMPTY for modern projects (2024+) — auth.py
# auto-fetches the public key from ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# and verifies ES256 / RS256 tokens.
SUPABASE_JWT_SECRET=

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# Weave observability (optional — set to enable @op tracing).
# https://wandb.ai/authorize
WEAVE_PROJECT=
WANDB_API_KEY=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Allowed CORS origins. Comma-separated list, or "*" for any (dev only).
# Defaults to the Next.js dev gateway when unset. Add the production Vercel
# URL here before deploying.
ALLOWED_ORIGIN=http://localhost:3000
